{
  "name": "superformdata",
  "version": "0.0.1",
  "description": "Serialize rich JavaScript values into form-style entries and decode them back again",
  "homepage": "https://github.com/samlaycock/superformdata#readme",
  "bugs": {
    "url": "https://github.com/samlaycock/superformdata/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samlaycock/superformdata.git"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "lint": "oxlint . --type-aware",
    "lint:fix": "oxlint . --type-aware --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun test && bun run build",
    "prepublishOnly": "bun run check",
    "ci:publish": "bun run check && changeset publish"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.8",
    "@types/bun": "latest",
    "happy-dom": "^20.8.8",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "tsdown": "^0.21.5",
    "typescript": "^5"
  }
}
